<view class="page-container bind-page">
  <view class="bind-hero">
    <view class="bind-orb bind-orb-a"></view>
    <view class="bind-orb bind-orb-b"></view>

    <view class="bind-card">
      <view class="bind-logo-panel">
        <image src="/images/logo.png" mode="aspectFit" class="logo-img" />
      </view>

      <view class="bind-title">欢迎使用电子名片</view>
      <view class="bind-desc">
        请输入管理员发给你的账号和密码，首次验证成功后会自动绑定当前微信。
      </view>

      <view class="password-form">
        <view class="form-item">
          <text class="form-label">账号</text>
          <view class="form-input-wrap">
            <input
              class="form-input"
              type="number"
              maxlength="11"
              placeholder="请输入员工手机号"
              value="{{phone}}"
              bindinput="onPasswordPhoneInput"
            />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">密码</text>
          <view class="form-input-wrap">
            <input
              class="form-input"
              password
              maxlength="20"
              placeholder="请输入密码"
              value="{{password}}"
              bindinput="onPasswordInput"
            />
          </view>
        </view>

        <view class="password-tip">密码需为 8-20 位，且必须同时包含字母和数字</view>
      </view>

      <view class="bind-action">
        <button
          class="btn-primary {{canSubmit ? '' : 'disabled'}}"
          disabled="{{!canSubmit || submitting}}"
          bindtap="onSubmit"
        >
          {{submitting ? '绑定中...' : '绑定并进入'}}
        </button>
      </view>
    </view>
  </view>

  <view class="bind-tip">
    <text class="text-assist">
      如果忘记密码，请联系管理员在 PC 后台为你重置密码。
    </text>
  </view>
</view>
