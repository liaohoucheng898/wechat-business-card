/* M7 个人数据统计页 */
.stats-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(22, 119, 255, 0.15) 0, rgba(22, 119, 255, 0) 220rpx),
    linear-gradient(180deg, #edf4ff 0%, #eaf2ff 220rpx, #f5f6fa 520rpx, #f5f6fa 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

.stats-hero {
  position: relative;
  padding: 52rpx 16rpx 64rpx;
  overflow: hidden;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hero-orb-a {
  width: 256rpx;
  height: 256rpx;
  top: 0;
  right: -84rpx;
  background: rgba(22, 119, 255, 0.10);
}

.hero-orb-b {
  width: 172rpx;
  height: 172rpx;
  left: -26rpx;
  top: 188rpx;
  background: rgba(22, 119, 255, 0.06);
}

.hero-orb-c {
  width: 120rpx;
  height: 120rpx;
  right: 146rpx;
  top: 226rpx;
  background: rgba(255, 255, 255, 0.28);
}

.hero-shell {
  position: relative;
  z-index: 1;
  padding: 16rpx 12rpx;
  border-radius: 44rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.34) 0%, rgba(255, 255, 255, 0.12) 100%);
  backdrop-filter: blur(8rpx);
}

.hero-shell-glow {
  position: absolute;
  inset: 8rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0.06) 100%);
}

.hero-card {
  position: relative;
  z-index: 1;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 36rpx;
  padding: 38rpx 30rpx 30rpx;
  box-shadow: 0 24rpx 60rpx rgba(10, 40, 120, 0.14);
}

.stats-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stats-summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.stats-summary-divider {
  width: 2rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(22, 119, 255, 0) 0%, rgba(22, 119, 255, 0.16) 22%, rgba(22, 119, 255, 0.16) 78%, rgba(22, 119, 255, 0) 100%);
}

.stats-summary-value {
  font-size: 78rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -2rpx;
  color: var(--color-primary);
}

.stats-summary-value-dark {
  color: var(--color-text-main);
}

.stats-summary-label {
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--color-text-secondary);
}

.stats-update-row {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.stats-update-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(22, 119, 255, 0.42);
}

.stats-update-time {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--color-text-assist);
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #DBDEE3;
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-assist);
  margin-top: 16rpx;
}

.time-tabs {
  display: flex;
  margin-top: 0;
  padding: 18rpx;
  gap: 14rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 34rpx rgba(15, 82, 204, 0.08);
}

.time-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background: #f6f8fc;
  transition: all 0.3s;
}

.time-tab.active {
  color: #fff;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 100%);
  box-shadow: 0 12rpx 24rpx rgba(22, 119, 255, 0.22);
  font-weight: 600;
}

.chart-card {
  margin-top: 22rpx;
  padding-bottom: 28rpx;
}

.chart-card .section-header {
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding-bottom: 18rpx;
}

.chart-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.chart-title-text {
  color: var(--color-text-main);
}

.chart-subtitle {
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--color-text-assist);
}

.chart-wrap {
  width: 100%;
  height: 420rpx;
  position: relative;
}

.trend-canvas {
  width: 100%;
  height: 420rpx;
}

.chart-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 320rpx;
}

.stats-encouragement {
  margin: 24rpx 16rpx 0;
  padding: 8rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 24rpx;
  line-height: 1.7;
  letter-spacing: 1rpx;
  color: #6f7f95;
}
