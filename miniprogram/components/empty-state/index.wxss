.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #727A8B;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #8F97A8;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: #3764F7;
  color: #fff;
  font-size: 30rpx;
  padding: 16rpx 48rpx;
  border-radius: 24rpx;
}
