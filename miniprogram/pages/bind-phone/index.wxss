.bind-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eaf2ff 0%, #f5f6fa 48%, #f5f6fa 100%);
}

.bind-hero {
  position: relative;
  padding: 112rpx 24rpx 0;
  overflow: hidden;
}

.bind-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
}

.bind-orb-a {
  width: 260rpx;
  height: 260rpx;
  top: 24rpx;
  right: -80rpx;
}

.bind-orb-b {
  width: 160rpx;
  height: 160rpx;
  top: 260rpx;
  left: -40rpx;
  background: rgba(22, 119, 255, 0.08);
}

.bind-card {
  position: relative;
  z-index: 1;
  background: #fff;
  border-radius: 36rpx;
  padding: 40rpx 28rpx 32rpx;
  box-shadow: var(--shadow-float);
}

.bind-logo-panel {
  width: 132rpx;
  height: 132rpx;
  margin: 0 auto 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #F4F8FF 0%, #EAF2FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-img {
  width: 88rpx;
  height: 88rpx;
}

.bind-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12rpx;
  text-align: center;
}

.bind-desc {
  font-size: 26rpx;
  color: var(--color-text-assist);
  text-align: center;
  line-height: 1.75;
  margin-bottom: 32rpx;
}

.mode-tabs {
  display: flex;
  padding: 8rpx;
  background: #F5F7FB;
  border-radius: 999rpx;
  margin-bottom: 28rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.mode-tab.is-active {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.18);
}

.password-form {
  width: 100%;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  margin-bottom: 14rpx;
}

.form-input-wrap {
  background: #fff;
  border-radius: 22rpx;
  border: 2rpx solid rgba(22, 119, 255, 0.10);
  padding: 0 26rpx;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.5);
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-main);
  height: 100rpx;
}

.password-tip {
  margin-top: 6rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--color-text-assist);
}

.bind-action {
  padding-top: 12rpx;
}

.bind-tip {
  text-align: center;
  padding: 28rpx 40rpx 40rpx;
  font-size: 24rpx;
}
