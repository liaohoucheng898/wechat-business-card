.phone-verify {
  width: 100%;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  margin-bottom: 14rpx;
}

.form-input-wrap {
  background: #fff;
  border-radius: 22rpx;
  border: 2rpx solid rgba(22, 119, 255, 0.10);
  padding: 0 26rpx;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.5);
}

.form-input-wrap:focus-within {
  border-color: rgba(22, 119, 255, 0.45);
  box-shadow: 0 0 0 10rpx rgba(22, 119, 255, 0.08);
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-main);
  height: 100rpx;
}

.code-wrap {
  padding-right: 10rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  flex-shrink: 0;
  min-width: 180rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 100%);
  color: #fff;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  font-weight: 600;
}

.code-btn.disabled {
  background: #C7CFDC;
}
