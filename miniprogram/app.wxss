/* ===== 全局样式变量 ===== */
page {
  --color-primary: #1677ff;
  --color-primary-deep: #0f52cc;
  --color-primary-soft: #eef4ff;
  --color-success: #0EC972;
  --color-warning: #FD8C43;
  --color-error: #F65146;
  --color-text-main: #1F2329;
  --color-text-secondary: #3D4A5C;
  --color-text-assist: #4A5568;
  --color-text-disabled: #BABFCB;
  --color-divider: #DBDEE3;
  --color-bg: #F5F6FA;
  --color-surface-soft: #F0F4FF;
  --font-family-base: Inter, "思源黑体", "Source Han Sans SC", "Source Han Sans CN", "Source Han Sans", sans-serif;
  --radius-card: 32rpx;
  --radius-panel: 24rpx;
  --radius-btn: 999rpx;
  --shadow-card: 0 16rpx 44rpx rgba(15, 82, 204, 0.10);
  --shadow-float: 0 20rpx 50rpx rgba(10, 40, 120, 0.18);

  background: var(--color-bg);
  color: var(--color-text-main);
  font-size: 30rpx;
  line-height: 1.6;
  font-family: var(--font-family-base);
}

view,
text,
button,
input,
textarea,
label,
navigator,
picker,
picker-view {
  font-family: var(--font-family-base);
}

/* ===== 通用工具类 ===== */
.page-container {
  min-height: 100vh;
  background: var(--color-bg);
}

.card-box {
  background: #fff;
  border-radius: var(--radius-card);
  margin: 24rpx 24rpx 0;
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}

.section-card {
  background: #fff;
  margin: 20rpx 24rpx 0;
  padding: 32rpx;
  border-radius: 28rpx;
  box-shadow: var(--shadow-card);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.section-header-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(22, 119, 255, 0.10);
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 600;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-deep) 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 600;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(22, 119, 255, 0.18);
}

.btn-primary::after {
  border: none;
}

.btn-primary.disabled {
  background: #C7CFDC;
  box-shadow: none;
}

.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-assist {
  color: var(--color-text-assist);
}

.divider {
  height: 1rpx;
  background: var(--color-divider);
}

.pill-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--color-text-assist);
  background: #fff;
  border: 1rpx solid var(--color-divider);
}

.pill-tag.active {
  color: #fff;
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
