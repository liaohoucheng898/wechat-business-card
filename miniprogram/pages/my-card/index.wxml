<!-- M4 我的名片页 -->
<view class="page-container my-card-page">
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{staffInfo && currentCard}}">
    <view class="hero">
      <view class="hero-orb hero-orb-a"></view>
      <view class="hero-orb hero-orb-b"></view>

      <view class="profile-card">
        <view class="profile-top">
          <view class="avatar-wrap" bindtap="onPreviewAvatar">
            <image
              class="avatar-img"
              src="{{currentCard.staff.avatar || defaultAvatar}}"
              mode="aspectFill"
            />
          </view>

          <view class="profile-info">
            <view class="profile-name">{{currentCard.staff.name}}</view>
            <view class="profile-title">{{currentCard.staff.title || '暂未填写职位'}}</view>
            <view class="profile-company">{{currentCard.company.name}}</view>
          </view>
        </view>

        <view class="profile-divider"></view>

        <view class="contact-list">
          <view class="contact-item" bindtap="onCallStaff">
            <image class="contact-icon" src="/images/card/contact-phone.svg" mode="aspectFit" />
            <text class="contact-text">{{currentCard.staff.phoneDisplay || currentCard.staff.phoneFull || currentCard.staff.phone || '暂未填写电话'}}</text>
          </view>

          <view class="contact-item" bindtap="onCopyEmail">
            <image class="contact-icon" src="/images/card/contact-email.svg" mode="aspectFit" />
            <text class="contact-text">{{currentCard.staff.email || '暂未填写邮箱'}}</text>
          </view>

          <view class="contact-item" bindtap="onOpenMap">
            <image class="contact-icon" src="/images/card/contact-address.svg" mode="aspectFit" />
            <text class="contact-text">{{currentCard.company.displayAddress || currentCard.company.address || currentCard.company.locationName || '暂未填写地址'}}</text>
          </view>
        </view>
      </view>

      <view
        wx:if="{{currentCard.staff.phoneDisplay || currentCard.staff.phoneFull || currentCard.staff.phone}}"
        class="call-phone-bar"
        bindtap="onCallStaff"
      >
        <text class="call-phone-bar-text">电话联系</text>
      </view>
    </view>

    <view class="section-card company-switch-panel">
      <view class="company-switch-list">
        <view
          wx:for="{{companyTabs}}"
          wx:key="companyId"
          class="company-switch-btn {{activeCompanyId === item.companyId ? 'active' : ''}} {{item.enabled ? '' : 'disabled'}}"
          bindtap="onCompanyTab"
          data-id="{{item.companyId}}"
          data-enabled="{{item.enabled}}"
        >{{item.companyName}}</view>
      </view>
    </view>

    <view class="section-card quick-entry">
      <view class="entry-item" bindtap="goStats">
        <view class="entry-left">
          <view class="entry-icon-badge">
            <image class="entry-icon-image" src="/images/my-card/feature-stats.svg" mode="aspectFit" />
          </view>
          <view class="entry-text-wrap">
            <text class="entry-text">数据统计</text>
            <text class="entry-subtext">查看近 7 天、15 天、30 天浏览趋势</text>
          </view>
        </view>
        <text class="entry-arrow">›</text>
      </view>
    </view>

    <view class="bottom-actions safe-bottom">
      <view class="action-edit" bindtap="goEdit">
        <text>编辑名片</text>
      </view>
      <button class="action-share" open-type="share">
        <text>分享名片</text>
      </button>
    </view>

    <view style="height: 180rpx;"></view>
  </block>

  <view wx:elif="{{!loading && !staffInfo}}" class="empty-wrap">
    <text class="empty-text">请先绑定手机号</text>
    <view class="btn-primary empty-btn" bindtap="goBind">去绑定</view>
  </view>
</view>
