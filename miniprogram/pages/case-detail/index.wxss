.case-detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f9fd 0%, #f5f6fa 100%);
  padding: 24rpx 0 calc(32rpx + env(safe-area-inset-bottom));
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #DBDEE3;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8F959E;
}

.detail-shell {
  padding: 0 16rpx;
}

.detail-card {
  overflow: hidden;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: var(--shadow-card);
}

.detail-cover-frame {
  position: relative;
  width: 100%;
  padding-top: 56.25%;
  overflow: hidden;
  background: #eef4ff;
}

.detail-cover,
.detail-cover-empty {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.detail-cover {
  display: block;
  background: #eef4ff;
  box-sizing: border-box;
}

.detail-cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef4ff;
  color: #8F959E;
  font-size: 26rpx;
}

.detail-header {
  padding: 36rpx 32rpx 0;
}

.detail-section {
  margin-bottom: 22rpx;
}

.detail-body {
  padding: 8rpx 32rpx 40rpx;
}

.detail-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1F2329;
}

.detail-title-group {
  margin-bottom: 28rpx;
}

.detail-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #646A73;
}

.detail-category-section {
  margin-bottom: 36rpx;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(22, 119, 255, 0.08);
  color: #1677ff;
  font-size: 24rpx;
}

.detail-content {
  font-size: 30rpx;
  line-height: 1.85;
  color: #1F2329;
}

.detail-empty {
  font-size: 26rpx;
  color: #8F959E;
}

.rich-wrapper {
  color: #1F2329;
  word-break: break-word;
}

.rich-wrapper p {
  margin: 0 0 28rpx;
}

.rich-wrapper p:last-child {
  margin-bottom: 0;
}

.rich-wrapper h1,
.rich-wrapper h2,
.rich-wrapper h3 {
  display: block;
  margin: 48rpx 0 24rpx;
  color: #1F2329;
  line-height: 1.5;
  font-weight: 700;
}

.rich-wrapper ul,
.rich-wrapper ol {
  margin: 0 0 28rpx;
  padding-left: 36rpx;
}

.rich-wrapper image,
.rich-wrapper img {
  display: block;
  max-width: 100%;
  height: auto;
  margin: 32rpx auto;
}
