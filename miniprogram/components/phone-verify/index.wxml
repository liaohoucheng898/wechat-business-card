<view class="phone-verify">
  <!-- 手机号输入 -->
  <view class="form-item">
    <text class="form-label">手机号</text>
    <view class="form-input-wrap">
      <input
        class="form-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
        disabled="{{phoneDisabled}}"
      />
    </view>
  </view>

  <!-- 验证码输入 -->
  <view class="form-item">
    <text class="form-label">验证码</text>
    <view class="form-input-wrap code-wrap">
      <input
        class="form-input code-input"
        type="number"
        maxlength="6"
        placeholder="请输入验证码"
        value="{{smsCode}}"
        bindinput="onCodeInput"
      />
      <view
        class="code-btn {{canSend ? '' : 'disabled'}}"
        bindtap="onSendCode"
      >
        <text>{{codeText}}</text>
      </view>
    </view>
  </view>
</view>
